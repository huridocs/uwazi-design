                        },
                        {
                          "type": "text",
                          "id": "wTWJp",
                          "name": "title",
                          "fill": "$text-primary",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "REPORT No. 187/20\nCASE 12.204\nADMISSIBILITY AND MERITS\nACTIVE MEMORY CIVIL ASSOCIATION\nARGENTINA\nJuly 14, 2020",
                          "lineHeight": 1.6,
                          "textAlign": "center",
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "700"
                        },
                        {
                          "type": "text",
                          "id": "Dqi0D",
                          "name": "sectionTitle",
                          "fill": "$text-primary",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "I.    INTRODUCTION",
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "700"
                        },
                        {
                          "type": "text",
                          "id": "oqeB4",
                          "name": "paragraph",
                          "fill": "$text-primary",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "1.    On July 16, 1999, the Inter-American Commission on Human Rights received a petition signed by a group of victims of the terrorist attack perpetrated against the headquarters of the Israeli-Argentinian Mutual Association [Asociación Mutual Israelita Argentina] (AMIA) organized through the Active Memory Civil Association.",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 12
                        },
                        {
                          "type": "text",
                          "id": "Quptl",
                          "name": "sectionTitle2",
                          "fill": "$text-primary",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "II.    PROCEDURE OF THE PETITION BEFORE THE IACHR",
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "700"
                        },
                        {
                          "type": "text",
                          "id": "7JW07",
                          "name": "paragraph2",
