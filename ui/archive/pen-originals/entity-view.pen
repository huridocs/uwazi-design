                          "lineHeight": 1.6,
                          "textAlign": "center",
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "700"
                        },
                        {
                          "type": "text",
                          "id": "QMvzg",
                          "name": "sectionTitle",
